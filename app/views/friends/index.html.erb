<% if user_signed_in? %>
<table class="table table-striped table-bordered table-hover">
  <thead class="thead-dark">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Github</th>
      <th colspan="1"></th>
    </tr>
  </thead>
  <tbody>
    <% @friends.each do |friend| %>
      <% if friend.user == current_user %>
      <tr>
        <td><%= link_to friend.first_name + ' ' + friend.last_name, friend %></td>
        <td><%= friend.email %></td>
        <td><%= friend.phone %></td>
        <td><%= friend.github %></td>
        <td><%= button_to "Delete", friend_path(friend), method: :delete, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline" }, data: { turbo_confirm: "Are you sure?" } %></td>
      </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
  <br>
<div class="actions">
  <%= link_to "Add New Friend", new_friend_path, class: "btn btn-secondary" %>
</div>
<% else %>
  <h1>Hello world</h1>
  <p>This is my first Rails Webpage</p>
<% end %>
