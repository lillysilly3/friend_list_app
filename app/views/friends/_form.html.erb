<%= form_with(model: friend, html: { autocomplete: "off" }) do |form| %>
  <% if friend.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(friend.errors.count, "error") %> prohibited this friend from being saved:</h2>

      <ul>
        <% friend.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.text_field :first_name, class: "form-control", placeholder: "First Name" %>
  </div>

  <div class="form-group">
    <%= form.text_field :last_name, class: "form-control", placeholder: "Last Name" %>
  </div>

  <div class="form-group">
    <%= form.email_field :email, class: "form-control", placeholder: "Email Address" %>
  </div>

  <div class="form-group">
    <%= form.telephone_field :phone, class: "form-control", placeholder: "Phone Number" %>
  </div>

  <div class="form-group">
    <%= form.text_field :github, class: "form-control", placeholder: "Github" %>
  </div>
<br>
  <div class="actions">
    <%= form.submit class:"btn btn-info" %>
    <%= link_to "Back", friends_path, class: "btn btn-secondary" %>
  </div>
<% end %>
